# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/

# Google service-account JSON keys (must NEVER be committed)
backend/credentials/
backend/credentials/*
**/credentials/*.json

# Test/admin credentials documentation (contains real passwords)
memory/test_credentials.md

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store
*.pem
*.key

# Python
__pycache__/
*.pyc
venv/
.venv/

# Development tools
chainlit.md
.chainlit
.ipynb_checkpoints/

# Deployment
.vercel

# Data and databases
agenthub/agents/youtube/db

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/
frontend/node_modules/.cache/

# NOTE: .env files ARE intentionally tracked so the Emergent Kubernetes
# deployer can ship them. Real production secrets must be injected via
# the platform's secret manager, not via committed .env values.
frontend/node_modules/.cache/default-development/1.pack
frontend/node_modules/.cache/default-development/24.pack
frontend/node_modules/.cache/default-development/9.pack
-e 
# Environment and credential files
.env
.env.*
*.env
credentials.json
*.pem
*.key
.credentials
